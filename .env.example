# RTSP Camera Configuration
rtspUrl="rtsp://admin:PASSWORD@192.168.0.100:5543/live/channel0"

# Google Drive Configuration (OAuth 2.0)
# See OAUTH_SETUP.md for detailed instructions
# This is the folder ID where recordings will be uploaded
# Get it from: https://drive.google.com/drive/folders/FOLDER_ID
SHARED_DRIVE_ID="your-folder-id-here"

# Storage Limit (in GB, default: 12)
STORAGE_LIMIT_GB=12

# Optional: Port (default: 5000)
PORT=5000
